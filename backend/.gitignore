```gitignore
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules/

# Build folders
dist
dist-ssr
coverage

# Environment files
.env
.env.local
.env.*.local
*.local

# Uploads
uploads/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea

# OS files
.DS_Store
Thumbs.db

# Visual Studio files
*.suo
*.ntvs*
*.njsproj
*.sln

# Swap files
*.sw?

# Temporary files
.tmp
.temp
.cache
```
